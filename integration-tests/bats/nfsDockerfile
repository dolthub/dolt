# syntax=docker/dockerfile:1
FROM golang:1.25-alpine AS golang_cgo125
ENV CGO_ENABLED=1
ENV GO_LDFLAGS="-linkmode external -extldflags '-static'"
RUN apk add --no-cache build-base

FROM golang_cgo125 AS source-binary
RUN apk add --no-cache icu-dev icu-static
COPY dolt/go/go.mod /build/dolt/go/
WORKDIR /build/dolt/go/
RUN go mod download
COPY dolt/go/ /build/dolt/go/
RUN go build -tags icu_static -ldflags "$GO_LDFLAGS" -o /build/bin/dolt ./cmd/dolt

FROM debian:bookworm-slim
RUN apt-get update -y && apt-get install -y \
  bats \
  e2fsprogs \
  iproute2 \
  kmod \
  lsof \
  netcat-openbsd \
  nfs-common \
  nfs-kernel-server \
  procps \
  && rm -rf /var/lib/apt/lists/*

COPY --from=source-binary /build/bin/dolt /usr/local/bin/dolt
RUN /usr/local/bin/dolt version \
 && dolt config --global --add user.email 'bats@email.fake' \
 && dolt config --global --add user.name 'Bats Tests'

VOLUME /var/lib/dolt
WORKDIR /var/lib/dolt
