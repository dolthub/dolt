#!/usr/bin/expect

set timeout 30
set env(NO_COLOR) 1

spawn dolt push origin main

# A passphrase prompt indicates that a git subprocess reached the PTY that
# expect allocated for dolt. Git subprocesses run in a new session with no
# controlling terminal, so SSH cannot open /dev/tty and must exit without prompting.
expect {
    -re "Enter passphrase" {
        puts "ERROR: passphrase prompt appeared; git subprocesses can reach the controlling terminal"
        exit 2
    }
    timeout {
        puts "ERROR: dolt push did not exit within the timeout"
        exit 1
    }
    eof {}
}

lassign [wait] - - - exit_status
exit $exit_status
