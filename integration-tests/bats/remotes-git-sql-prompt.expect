#!/usr/bin/expect

set timeout 5
set env(NO_COLOR) 1

source "$env(BATS_CWD)/helper/common_expect_functions.tcl"

spawn dolt sql
expect_with_defaults {>} {}
send "CALL DOLT_PUSH('origin', 'main');\r"
expect_with_defaults {Enter passphrase:} { send "hunter2\r" }
expect_with_defaults {>} {}
send "select v from t where pk = 2;\r"
expect_with_defaults {99} {}
send "exit\r"
expect eof
lassign [wait] - - - exit_status
exit $exit_status
